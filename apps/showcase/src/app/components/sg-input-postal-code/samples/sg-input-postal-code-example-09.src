<SgInputPostalCode
  id="demo-iconbtns"
  label="${t(i18n, "showcase.component.inputPostalCode.labels.copyText")}"
  hintText="00000-000"
  name="iconbtns"
  register={register}
  iconButtons={[
    <button key="copy" type="button" onClick={() => navigator.clipboard.writeText(value)}>
      Copiar
    </button>,
    <button key="alert" type="button" onClick={() => alert("ok")}>
      Alerta
    </button>
  ]}
/>