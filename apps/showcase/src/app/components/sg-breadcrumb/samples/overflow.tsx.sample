  { id: "admin", label: "Admin", href: "/admin" },
  { id: "tenant", label: "Multi Tenancy", href: "/admin/tenant" },
  { id: "billing", label: "Billing", href: "/admin/tenant/billing" },
  { id: "plans", label: "Subscription", href: "/admin/tenant/billing/subscription" },
