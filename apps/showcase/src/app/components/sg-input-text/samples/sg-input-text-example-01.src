<SgInputText
  id="demo-basic"
  label="${t(i18n, "showcase.component.inputText.labels.fullName")}"
  name="nome"
  register={register}
/>

<button type="submit">
  ${t(i18n, "showcase.component.inputText.actions.submit")}
</button>

<p>${t(i18n, "showcase.common.labels.currentValue", { value: watch("nome") })}</p>